<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Primuse</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Primuse</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.welape.yuanyin.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>primuse</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.welape.yuanyin.google-oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(GOOGLE_REVERSED_CLIENT_ID)</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.welape.yuanyin.microsoft-oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>msauth.$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>PrimuseMacAppStoreID</key>
	<string>$(PRIMUSE_MAC_APP_STORE_ID)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.music</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSAppleMusicUsageDescription</key>
	<string>Primuse needs access to your Apple Music / iTunes library to import its local tracks as a playback source.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_smb._tcp.</string>
		<string>_webdav._tcp.</string>
		<string>_webdavs._tcp.</string>
		<string>_ftp._tcp.</string>
		<string>_sftp-ssh._tcp.</string>
		<string>_nfs._tcp.</string>
		<string>_diskstation._tcp.</string>
		<string>_synology-dsm._tcp.</string>
		<string>_http._tcp.</string>
		<string>_https._tcp.</string>
	</array>
	<key>NSHumanReadableCopyright</key>
	<string>© Welape</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Primuse needs local network access to discover and connect to your NAS devices, media servers, and other music sources.</string>
	<key>PrimuseBaiduClientID</key>
	<string>$(BAIDU_CLIENT_ID)</string>
	<key>PrimuseBaiduClientSecret</key>
	<string>$(BAIDU_CLIENT_SECRET)</string>
	<key>PrimuseDropboxClientID</key>
	<string>$(DROPBOX_CLIENT_ID)</string>
	<key>PrimuseDropboxClientSecret</key>
	<string>$(DROPBOX_CLIENT_SECRET)</string>
	<key>PrimuseGoogleClientID</key>
	<string>$(GOOGLE_CLIENT_ID)</string>
	<key>PrimuseGoogleReversedClientID</key>
	<string>$(GOOGLE_REVERSED_CLIENT_ID)</string>
	<key>PrimuseOneDriveClientID</key>
	<string>$(ONEDRIVE_CLIENT_ID)</string>
</dict>
</plist>
